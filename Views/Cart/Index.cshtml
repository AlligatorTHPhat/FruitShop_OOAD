@model IEnumerable<FruitShopG4P.ViewModels.CartItem>
@{
    ViewData["Title"] = "Gio Hang";
    var subtotal = Model.Sum(p => p.ThanhTien);
    var shipping = 10000;
    var total = subtotal + shipping;
}

<div class="container-fluid py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mb-5">
                <div class="table-responsive cart-table-wrapper p-4">
                    <table class="table table-borderless text-center mb-0 align-middle">
                        <thead class="cart-thead text-secondary">
                            <tr>
                                <th class="text-start">Sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Tổng</th>
                                <th>Xóa</th>
                            </tr>
                        </thead>
                        <tbody class="align-middle">
                            @foreach (var item in Model)
                            {
                                <tr class="cart-item-row border-bottom">
                                    <td class="text-start">
                                        <div class="d-flex align-items-center">
                                            <div class="img-wrapper me-3">
                                                <img src="@Url.Content("~/Hinh/HangHoa/" + item.Hinh)" alt="@item.TenHH" />
                                            </div>
                                            <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@item.MaHH" class="product-name">
                                                @item.TenHH
                                            </a>
                                        </div>
                                    </td>
                                    <td class="fw-bold text-muted">@item.DonGia.ToString("#,##0")</td>
                                    <td>
                                        <form asp-action="UpdateCart" asp-controller="Cart" method="post">
                                            <input type="hidden" name="id" value="@item.MaHH" />
                                            <div class="quantity-control d-flex align-items-center justify-content-center">
                                                <button class="btn btn-qty" type="submit" name="change" value="-1">
                                                    <i class="fa fa-minus"></i>
                                                </button>
                                                <input type="text" class="form-control border-0 text-center qty-input mx-2" name="quantity" value="@item.SoLuong" readonly>
                                                <button class="btn btn-qty" type="submit" name="change" value="1">
                                                    <i class="fa fa-plus"></i>
                                                </button>
                                            </div>
                                        </form>
                                    </td>
                                    <td class="fw-bold text-primary">@item.ThanhTien.ToString("#,##0")</td>
                                    <td>
                                        <a asp-action="RemoveToCart" asp-controller="Cart" asp-route-id="@item.MaHH" class="btn btn-remove">
                                            <i class="fa fa-times"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-4">
                <form class="mb-30" action="">
                    <div class="input-group coupon-group shadow-sm">
                        <input type="text" class="form-control p-4 border-0" placeholder="Nhập mã giảm giá">
                        <div class="input-group-append">
                            <button class="btn btn-apply">Áp dụng</button>
                        </div>
                    </div>
                </form>

                <h5 class="section-title position-relative text-uppercase mb-3 mt-4 summary-header">
                    <span class="summary-title-banner px-4 py-2 text-white">
                        Tóm tắt thanh toán
                    </span>
                </h5>

                <div class="cart-summary p-4 mb-5">
                    <table class="table table-borderless summary-table mb-0">
                        <tbody>
                            <tr class="summary-row border-bottom">
                                <td class="text-muted ps-0">Tổng tiền hàng:</td>
                                <td class="text-end fw-bold">@Model.Sum(p => p.ThanhTien).ToString("#,##0") VNĐ</td>
                            </tr>
                            <tr class="summary-row">
                                <td class="text-muted ps-0">Phí vận chuyển:</td>
                                <td class="text-end fw-medium">@shipping.ToString("#,##0") VNĐ</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="pt-3 border-top summary-total-section">
                        <div class="d-flex justify-content-between mt-2 total-row">
                            <h5 class="fw-bold ps-0">Tổng cộng:</h5>
                            <h5 class="text-primary font-weight-bold">@total.ToString("#,##0") VNĐ</h5>
                        </div>

                        <form asp-action="Checkout" asp-controller="Cart" method="get">
                            <button type="submit" class="btn btn-block btn-checkout font-weight-bold my-3 py-3 w-100">
                                Tiến hành thanh toán
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
    /* --- CSS THEME VÀ CẤU TRÚC CHUNG --- */
    :root {
        --main-green: #27ae60; /* Xanh lá cây đậm */
        --main-orange: #f39c12; /* Cam chủ đạo */
    }

    body {
        background-color: #f4f6f9; /* Màu nền web hơi xám nhẹ */
    }

    .cart-table-wrapper, .cart-summary {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    }

    /* --- BẢNG SẢN PHẨM (TRÁI) --- */
    .cart-thead th {
        border: none;
        text-transform: uppercase;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 1px;
        padding-bottom: 20px;
    }

    .cart-item-row:last-child {
        border-bottom: none !important;
    }

    /* Ảnh sản phẩm */
    .img-wrapper img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #eee;
    }

    /* Tên sản phẩm */
    .product-name {
        color: #2c3e50;
        font-weight: 600;
        text-decoration: none;
        font-size: 1rem;
        transition: 0.2s;
    }

        .product-name:hover {
            color: var(--main-orange);
        }

    /* Nút tăng giảm số lượng */
    .quantity-control {
        background: #f8f9fa;
        border-radius: 50px;
        padding: 5px;
        width: fit-content;
        margin: 0 auto;
    }

    .qty-input {
        background: transparent !important;
        width: 40px;
        font-weight: bold;
        color: #333;
    }

    .btn-qty {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #fff;
        border: 1px solid #eee;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
        font-size: 0.8rem;
    }

        .btn-qty:hover {
            background: var(--main-orange);
            color: white;
            border-color: var(--main-orange);
        }

    /* Nút xóa */
    .btn-remove {
        color: #e74c3c;
        background: rgba(231, 76, 60, 0.1);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        transition: 0.3s;
    }

        .btn-remove:hover {
            background: #e74c3c;
            color: white;
            transform: rotate(90deg);
        }

    /* --- TÓM TẮT THANH TOÁN (PHẢI) --- */

    /* Tiêu đề Banner */
    .summary-header {
        position: relative;
        margin-top: 30px !important;
        margin-bottom: 0px !important;
    }

    .summary-title-banner {
        background-color: var(--main-green) !important;
        color: white !important;
        border-radius: 8px 8px 8px 0;
        display: inline-block;
        font-size: 1.15rem;
        box-shadow: 0 4px 10px rgba(39, 174, 96, 0.4);
    }

    /* Khung chính Summary */
    .cart-summary {
        border-radius: 12px;
        padding-top: 20px !important;
        border: 1px solid #f0f0f0;
    }

    /* Bảng chi tiết tiền */
    .summary-table {
        width: 100%;
        margin-bottom: 0 !important;
    }

        .summary-table td {
            padding: 8px 0 !important;
            font-size: 1rem;
        }

        .summary-table .border-bottom {
            border-bottom: 1px dashed #e0e0e0 !important;
            padding-bottom: 15px !important;
        }

    /* Khu vực Tổng cộng cuối cùng */
    .summary-total-section {
        border-top: 1px solid #f0f0f0 !important;
        padding-top: 20px !important;
    }

        .summary-total-section h5 {
            font-size: 1.5rem;
            color: #2c3e50;
        }

    /* Input Coupon */
    .coupon-group {
        border-radius: 50px;
        background: #fff;
        overflow: hidden;
    }

        .coupon-group input {
            border-radius: 50px 0 0 50px !important;
        }

    .btn-apply {
        background: #2c3e50;
        color: #fff;
        border-radius: 0 50px 50px 0;
        padding: 0 25px;
        transition: 0.3s;
        border: none;
    }

        .btn-apply:hover {
            background: #34495e;
        }

    /* Nút Thanh toán (CTA) */
    .btn-checkout {
        background: linear-gradient(45deg, #f6a623, #f39c12);
        color: white !important;
        border-radius: 50px;
        border: none;
        box-shadow: 0 4px 15px rgba(243, 156, 18, 0.4);
        transition: 0.3s;
    }

        .btn-checkout:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(243, 156, 18, 0.6);
            background: linear-gradient(45deg, #f39c12, #e67e22);
        }

    /* Màu chữ chủ đạo */
    .text-primary {
        color: var(--main-orange) !important;
    }

    .text-muted {
        color: #7f8c8d !important;
    }
</style>


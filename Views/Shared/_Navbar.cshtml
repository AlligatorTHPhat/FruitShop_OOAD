
@{
    ViewData["Title"] = "_Navbar";
}

<!-- Navbar start -->
<div class="container-fluid fixed-top">
    <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
            <div class="top-info ps-2">
                <small class="me-3"><i class="fas fa-map-marker-alt me-2 text-secondary"></i> <a href="#" class="text-white">280 An Duong Vuong, District 5 Ho Chi Minh City</a></small>
                <small class="me-3"><i class="fas fa-envelope me-2 text-secondary"></i><a href="#" class="text-white">tranhoangphat2311@gmail.com</a></small>
            </div>
            @*<div class="top-link pe-2">
                <a href="#" class="text-white"><small class="text-white mx-2">Privacy Policy</small>/</a>
                <a href="#" class="text-white"><small class="text-white mx-2">Terms of Use</small>/</a>
                <a href="#" class="text-white"><small class="text-white ms-2">Sales and Refunds</small></a>
            </div>*@
        </div>
    </div>
    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-xl">
            <a href="index.html" class="navbar-brand"><h1 class="text-primary display-6">Fruitables</h1></a>
            <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars text-primary"></span>
            </button>
            <div class="navbar-nav mx-auto">
                <a asp-controller="Home" asp-action="Index" class="nav-item nav-link">Trang chủ</a>

                <a asp-controller="HangHoa" asp-action="Index" class="nav-item nav-link">Cửa Hàng</a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Cart" asp-action="Index" class="nav-item nav-link">Giỏ Hàng</a>
                    <a asp-controller="KhachHang" asp-action="Profile" class="nav-item nav-link">Thông Tin Của Bạn</a>
                    <a asp-controller="KhachHang" asp-action="DangXuat" class="nav-item nav-link text-danger">Đăng Xuất</a>
                }
                else
                {
                    <a asp-controller="KhachHang" asp-action="DangKy" class="nav-item nav-link">Đăng Ký</a>
                    <a asp-controller="KhachHang" asp-action="DangNhap" class="nav-item nav-link text-primary">Đăng Nhập</a>
                }
                <div class="nav-item border-start ps-3 ms-3 d-none d-xl-block"></div>
                <a asp-controller="DangNhap" asp-action="Index" class="nav-item nav-link text-success">
                    <i class="fas fa-user-shield me-1"></i> Nhân viên
                </a>
            </div>
        </nav>
    </div>
</div>
<!-- Navbar End -->
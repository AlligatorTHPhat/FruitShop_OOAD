@model FruitShopG4P.ViewModels.LoginVM
@{
    ViewData["Title"] = "Index";
}

<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4 text-center">Đăng nhập</h1>

        <div class="row justify-content-center">

            <div class="col-md-8 col-lg-6 mx-auto">

                <form asp-action="Index" method="post">

                    <div class="form-item w-100">
                        <label asp-for="UserName" class="form-label my-3">Tài Khoản<sup>*</sup></label>
                        <input asp-for="UserName" type="text" class="form-control">
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <div class="form-item w-100">
                        <label asp-for="Password" class="form-label my-3">Mật khẩu<sup>*</sup></label>
                        <input asp-for="Password" type="password" text="password" class="form-control">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="row g-4 text-center justify-content-center pt-4">
                        <button type="submit" class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary">
                            Đăng nhập
                        </button>
                    </div>

                    <div class="text-end mt-2">
                        <a asp-controller="DangNhap" asp-action="QuenMatKhau" class="btn btn-link">
                            Quên mật khẩu?
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>




@{
    ViewData["Title"] = "IndexAdmin";
}

@{
    ViewData["Title"] = "Trang Quản Trị";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <style>
        /* Màu nền tổng thể sáng và chữ đậm */
        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
            /* Thay đổi: Nền Xanh Nhạt */
            background-color: #e3f2fd;
            color: #1f2937;
        }

        /* Particles.js */
        #particles-js {
            position: absolute;
            width: 100%;
            height: 100%;
            /* Thay đổi: Nền Xanh Nhạt */
            background-color: #e3f2fd;
            z-index: -1;
        }

        .admin-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            text-align: center;
            color: #1f2937;
        }

        .admin-title {
            font-size: 38px;
            font-weight: 700;
            /* Thay đổi: Màu Xanh Dương Chủ Đạo */
            color: #0d47a1;
            margin-bottom: 50px;
            /* Thay đổi: Bóng Xanh Nhạt */
            text-shadow: 1px 1px #bbdefb;
        }

        .admin-buttons .btn {
            min-width: 240px;
            margin: 12px;
            font-size: 18px;
            padding: 14px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: none;
        }

        /* Định nghĩa màu cho từng nút cụ thể theo yêu cầu */

        /* 1. Quản lý Nhân viên: Xanh Dương (Màu chủ đạo) */
        .btn-nv {
            background-color: #1976d2; /* Xanh dương đậm */
            color: white;
        }

        /* 2. Quản lý Hàng hóa: Xanh Lá Nhạt (Light Green) */
        .btn-hh {
            background-color: #8BC34A; /* Xanh lá nhạt */
            color: white;
        }

        /* 3. Quản lý Khách hàng: Vàng (Yellow) */
        .btn-kh {
            background-color: #ffc107; /* Vàng */
            color: white;
        }

        /* 4. Quản lý Đơn hàng: Cam (Orange) */
        .btn-hd {
            background-color: #ff9800; /* Cam */
            color: white;
        }

        /* 5. Đăng xuất: Đỏ (Giữ nguyên cho Đăng xuất) */
        .btn-danger {
            background-color: #dc2626;
            color: white;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            opacity: 0.9;
        }
    </style>
</head>
<body>
    <div id="particles-js"></div>

    <div class="admin-container">
        <div class="admin-title">TRANG QUẢN TRỊ CỬA HÀNG TRÁI CÂY</div>
        <div class="admin-buttons">
            <a asp-controller="NhanVien" asp-action="Index" class="btn btn-nv">Quản trị Nhân viên</a>
            <a asp-controller="QuanLyHangHoa" asp-action="Create" class="btn btn-hh">Nhập thêm hàng hóa mới</a>
            <a asp-controller="QuanLyKhachHang" asp-action="Index" class="btn btn-kh">Quản trị Khách hàng</a>
            <a asp-controller="DangNhap" asp-action="DangXuat" class="btn btn-danger">Đăng xuất</a>
            </div>
        </div>

    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <script>
        particlesJS("particles-js", {
            particles: {
                number: { value: 80, density: { enable: true, value_area: 800 } },
                color: { value: "#059669" }, /* Đổi màu chấm sang xanh lá */
                shape: { type: "circle" },
                opacity: { value: 0.6 },
                size: { value: 3 },
                line_linked: {
                    enable: true,
                    distance: 150,
                    color: "#34d399", /* Màu dây nối xanh lá nhạt */
                    opacity: 0.4,
                    width: 1
                },
                move: {
                    enable: true,
                    speed: 4,
                    direction: "none",
                    out_mode: "bounce"
                }
            },
            interactivity: {
                detect_on: "canvas",
                events: {
                    onhover: { enable: true, mode: "repulse" },
                    onclick: { enable: true, mode: "push" }
                },
                modes: {
                    repulse: { distance: 100 },
                    push: { particles_nb: 4 }
                }
            },
            retina_detect: true
        });
    </script>
</body>
</html>


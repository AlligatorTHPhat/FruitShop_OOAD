@model FruitShopG4P.Data.HangHoa

@{
    Layout = null;
    ViewData["Title"] = "Chỉnh sửa Hàng Hóa";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            /* Background Gradient: Light Green/Lime */
            background: linear-gradient(135deg, #f1f8e9, #c5e1a5); /* Từ màu xanh rất nhạt đến xanh chanh nhạt */
            font-family: 'Segoe UI', sans-serif;
            padding: 40px;
        }

        .container-box {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            max-width: 700px;
            margin: 0 auto;
        }

        h1 {
            /* Title Color: Darker Lime Green */
            color: #689f38; /* Xanh lá cây đậm để nổi bật */
            font-weight: bold;
            margin-bottom: 30px;
            text-align: center;
        }


        /* Styling the back link */
        .container-box > a {
            color: #8BC34A; /* Màu xanh lá chanh chính */
            font-weight: bold;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 20px;
        }

            .container-box > a:hover {
                color: #689f38; /* Xanh lá cây đậm hơn khi hover */
                text-decoration: underline;
            }

        .form-group label {
            font-weight: 600;
            color: #333;
        }

        .form-control {
            /* Border Color: Light Lime Green */
            border: 2px solid #aed581; /* Xanh lá cây nhạt hơn */
            border-radius: 10px;
            padding: 12px 15px;
            transition: 0.3s ease;
        }

            .form-control:focus {
                /* Focus Border Color: Main Lime Green */
                border-color: #8BC34A; /* Màu xanh lá chanh chính */
                /* Focus Shadow: Lime Green Shadow */
                box-shadow: 0 0 10px rgba(139, 195, 74, 0.3); /* Ánh sáng màu xanh chanh */
            }

        .btn-submit {
            /* Button Gradient: Lime Green Gradient */
            background: linear-gradient(45deg, #8BC34A, #689f38); /* Gradient từ xanh chanh đến xanh đậm */
            color: white;
            border: none;
            border-radius: 25px;
            font-weight: bold;
            width: 100%;
            padding: 12px;
            transition: 0.3s;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                /* Hover Shadow: Lime Green Shadow */
                box-shadow: 0 5px 15px rgba(139, 195, 74, 0.4); /* Ánh sáng màu xanh chanh */
            }

        .text-danger {
            font-size: 14px;
            color: #d32f2f; /* Giữ màu đỏ tiêu chuẩn cho lỗi (hoặc đổi sang màu xanh đậm hơn nếu muốn tông đồng nhất) */
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="container-box">
            <a asp-action="Index">← Quay lại danh sách</a>
            <h1>Cập nhật thông tin hàng hóa</h1>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="MaHh" />
                <input type="hidden" asp-for="MaNcc" value="NCC01" />
                <input type="hidden" asp-for="MaLoai" value="1" />

                <div class="form-group">
                    <label asp-for="Hinh"></label>
                    <br />
                    @if (!string.IsNullOrEmpty(Model.Hinh))
                    {
                        <img id="imagePreview" src="~/Hinh/HangHoa/@Model.Hinh" alt="@Model.TenHh"
                                            style="width:150px; height:150px; object-fit:cover; border-radius:8px; margin-bottom:10px;" />
                    }
                    else
                    {
                        <span>Chưa có ảnh</span>
                    }
                    <input asp-for="Hinh" type="file" class="form-control" id="imageUpload" accept="image/*" onchange="previewImage(this)" />
                    <small class="text-muted">Bỏ trống nếu không muốn đổi ảnh</small>
                    <span asp-validation-for="Hinh" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="TenHh"></label>
                    <input asp-for="TenHh" class="form-control" />
                    <span asp-validation-for="TenHh" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="TenAlias"></label>
                    <input asp-for="TenAlias" class="form-control" />
                    <span asp-validation-for="TenAlias" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="TenAlias"></label>
                    <input asp-for="TenAlias" class="form-control" />
                    <span asp-validation-for="TenAlias" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DonGia"></label>
                    <input asp-for="DonGia" class="form-control" />
                    <span asp-validation-for="DonGia" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Số lượng tồn kho</label>
                    <input asp-for="SoLuongTonKho" type="number" class="form-control" />
                </div>

                <div class="form-group">
                    <label asp-for="NgaySx"></label>
                    <input name="NgaySx" type="date" class="form-control" value="@Model.NgaySx.ToString("yyyy-MM-dd")" />
                </div>

                <div class="form-group">
                    <label asp-for="HanSd"></label>
                    <input name="HanSd" type="date" class="form-control" value="@(Model.HanSd?.ToString("yyyy-MM-dd"))" />
                </div>

                @* <div class="form-group">
                    <label asp-for="GiamGia"></label>
                    <input asp-for="GiamGia" class="form-control" />
                    <span asp-validation-for="GiamGia" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SoLanXem"></label>
                    <input asp-for="SoLanXem" class="form-control" />
                    <span asp-validation-for="SoLanXem" class="text-danger"></span>
                </div> *@

                <div class="form-group">
                    <label asp-for="MaNcc">Nhà cung cấp</label>
                    <input asp-for="MaNcc" type="text" class="form-control" />
                    <span asp-validation-for="MaNcc" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MoTa"></label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="MoTa" class="text-danger"></span>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn-submit">Cập nhật hàng hóa</button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
        <script>

            // Preview ảnh khi chọn file mới
            function previewImage(input) {
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById('imagePreview').src = e.target.result;
                    };
                    reader.readAsDataURL(input.files[0]);
                }
            }
        </script>
    }
</body>
</html>


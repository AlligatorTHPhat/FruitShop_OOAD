@{
    ViewData["Title"] = "Trang Nhân Viên";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <style>
        /* Đồng bộ màu nền Xanh Nhạt giống Admin */
        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
            background-color: #e3f2fd;
            color: #1f2937;
        }

        #particles-js {
            position: absolute;
            width: 100%;
            height: 100%;
            background-color: #e3f2fd; /* Đồng bộ nền particles */
            z-index: -1;
        }

        .admin-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            text-align: center;
            color: #1f2937;
        }

        .admin-title {
            font-size: 38px;
            font-weight: 700;
            /* Màu Xanh Dương Chủ Đạo giống Admin */
            color: #0d47a1;
            margin-bottom: 50px;
            text-shadow: 1px 1px #bbdefb;
        }

        .admin-buttons .btn {
            min-width: 240px;
            margin: 12px;
            font-size: 18px;
            padding: 14px 24px;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border: none;
        }

        /* --- Đồng bộ màu nút bấm --- */

        /* 1. Thông tin cá nhân (Dùng màu Xanh Dương của NV) */
        .btn-nv {
            background-color: #1976d2;
            color: white;
        }

        /* 2. Quản lý Hàng hóa: Xanh Lá Nhạt giống Admin */
        .btn-hh {
            background-color: #8BC34A;
            color: white;
        }

        /* 3. Quản lý Đơn hàng: Cam giống Admin */
        .btn-hd {
            background-color: #ff9800;
            color: white;
        }

        /* 4. Đăng xuất: Đỏ */
        .btn-danger {
            background-color: #dc2626;
            color: white;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            opacity: 0.9;
            color: white;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div id="particles-js"></div>

    <div class="admin-container">
        <div class="admin-title">TRANG NHÂN VIÊN</div>
        <div class="admin-buttons">
            <a asp-controller="NhanVien" asp-action="Profile" class="btn btn-nv">Thông tin cá nhân</a>
            <a asp-controller="QuanLyHangHoa" asp-action="Index" class="btn btn-hh">Quản trị hàng hóa</a>
            <a asp-controller="HoaDon" asp-action="Index" class="btn btn-hd">Quản trị hóa đơn</a>
            <a asp-controller="DangNhap" asp-action="DangXuat" class="btn btn-danger">Đăng xuất</a>
        </div>
    </div>

    <!-- particles.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <script>
        particlesJS("particles-js", {
            particles: {
                number: { value: 80, density: { enable: true, value_area: 800 } },
                color: { value: "#ffffff" },
                shape: { type: "circle" },
                opacity: { value: 0.5 },
                size: { value: 3 },
                line_linked: {
                    enable: true,
                    distance: 150,
                    color: "#ffffff",
                    opacity: 0.4,
                    width: 1
                },
                move: {
                    enable: true,
                    speed: 4,
                    direction: "none",
                    out_mode: "bounce"
                }
            },
            interactivity: {
                detect_on: "canvas",
                events: {
                    onhover: { enable: true, mode: "repulse" },
                    onclick: { enable: true, mode: "push" }
                },
                modes: {
                    repulse: { distance: 100 },
                    push: { particles_nb: 4 }
                }
            },
            retina_detect: true
        });
    </script>
</body>
</html>

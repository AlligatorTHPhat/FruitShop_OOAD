@model FruitShopG4P.Data.NhanVien

@{
    Layout = null;
    ViewData["Title"] = "Cập Nhật Nhân Viên";

    @*// Khôi phục logic hiển thị hình ảnh
    var imageSrc = !string.IsNullOrEmpty(Model.HinhNv)
        ? Url.Content("~/Hinh/NhanVien/" + Model.HinhNv)
        : Url.Content("~/Hinh/default-avatar.jpg");*@
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet" />
    <style>
        /* CSS Chủ đề Cửa hàng Trái cây */
        body {
            /* Nền: Xanh lá cây rất nhạt (Fruit Shop Theme) */
            background: linear-gradient(135deg, #e6ffe6, #f0fff0);
            font-family: 'Segoe UI', sans-serif;
            padding: 40px;
        }

        .container-box {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            max-width: 800px;
            margin: 0 auto;
        }

        h1 {
            /* Màu tiêu đề: Xanh lá cây tươi */
            color: #059669;
            font-weight: bold;
            margin-bottom: 30px;
            text-align: center;
        }

        .form-group label {
            font-weight: 600;
            color: #333;
        }

        .form-control {
            /* Viền mặc định: Xanh lá cây nhạt */
            border: 2px solid #a7f3d0;
            border-radius: 10px;
            padding: 12px 15px;
            transition: 0.3s ease;
        }

            .form-control:focus {
                /* Viền focus: Xanh lá cây đậm */
                border-color: #059669;
                box-shadow: 0 0 10px rgba(5, 150, 105, 0.3);
            }

        .btn-submit {
            /* Gradient Xanh lá cây đậm */
            background: linear-gradient(45deg, #10b981, #059669);
            color: white;
            border: none;
            border-radius: 25px;
            font-weight: bold;
            width: 100%;
            padding: 12px;
            transition: 0.3s;
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(5, 150, 105, 0.4);
            }

        .image-upload-section {
            text-align: center;
            margin-bottom: 20px;
        }

        .image-preview {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            /* Viền hình ảnh: Vàng cam */
            border: 4px solid #facc15;
            margin-bottom: 15px;
        }

        .upload-btn {
            /* Gradient Vàng cam */
            background: linear-gradient(45deg, #facc15, #eab308);
            color: #1f2937; /* Chữ đậm */
            padding: 8px 16px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            display: inline-block;
            transition: 0.3s;
        }

            .upload-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(250, 202, 21, 0.4);
            }

        #imageUpload {
            display: none;
        }

        .password-input-container {
            position: relative;
        }

        /* Cải tiến Password Toggle */
        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #9ca3af;
            cursor: pointer;
            padding: 0;
            font-size: 16px;
        }

            .password-toggle:hover {
                color: #059669; /* Xanh lá cây */
            }

        .text-danger {
            font-size: 14px;
        }

        .radio-group {
            display: flex;
            gap: 30px;
            padding-top: 10px;
        }

        /* Back Link */
        .back-link-custom {
            color: #eab308; /* Vàng cam */
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            transition: all 0.3s ease;
        }

            .back-link-custom:hover {
                color: #d97706;
                text-decoration: none;
            }

        /* Thêm style cho Checkbox Hiệu lực */
        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .checkbox-item input[type="checkbox"] {
                width: 20px;
                height: 20px;
                accent-color: #059669; /* Màu xanh lá cây cho checkbox */
            }

    </style>
</head>
<body>
    <div class="container">
        <div class="container-box">
            <a href="@Url.Action("Index", "NhanVien")" class="back-link-custom mb-3 d-block">
                <i class="fas fa-chevron-left"></i> Quay lại 
            </a>
            <h1><i class="fas fa-user-edit mr-2"></i> @ViewData["Title"]</h1>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @*<div class="image-upload-section">
                    <img id="imagePreview" src="@imageSrc" alt="Avatar" class="image-preview" />
                    <br>
                    <label for="imageUpload" class="upload-btn">
                        <i class="fas fa-camera mr-2"></i> Thay đổi ảnh đại diện
                    </label>
                    <input type="file" id="imageUpload" name="fHinh" accept="image/*" onchange="previewImage(this)" />
                    <input type="hidden" asp-for="HinhNv" /> <br><small class="text-muted">Bỏ trống nếu không muốn đổi ảnh</small>
                </div>*@

                <input type="hidden" asp-for="MaNv" />
                <input type="hidden" asp-for="EmailNv" />
                <input type="hidden" asp-for="RandomKeyNv" />
                <input type="hidden" asp-for="MatKhauNv" /> <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="HoTenNv">Họ tên</label>
                        <input asp-for="HoTenNv" class="form-control" />
                        <span asp-validation-for="HoTenNv" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="EmailNv">Email (Không được sửa)</label>
                        <input asp-for="EmailNv" type="email" class="form-control" readonly style="background-color: #f5f5f5;" />
                        <span asp-validation-for="EmailNv" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label for="MatKhauMoi">Mật khẩu mới (để trống nếu không đổi)</label>
                    <div class="password-input-container">
                        <input name="MatKhauMoi" type="password" class="form-control" id="passwordField" />
                        <button type="button" class="password-toggle" onclick="togglePassword('passwordField', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="NgaySinhNv">Ngày sinh</label>
                        <input asp-for="NgaySinhNv" type="date" class="form-control"/>
                        <span asp-validation-for="NgaySinhNv" class="text-danger"></span>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="DienThoaiNv">Điện Thoại</label>
                        <input asp-for="DienThoaiNv" class="form-control" />
                        <span asp-validation-for="DienThoaiNv" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="DiaChiNv">Địa chỉ</label>
                    <textarea asp-for="DiaChiNv" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="DiaChiNv" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label>Giới tính</label>
                        <div class="radio-group">
                            <div class="radio-item">
                                <input asp-for="GioiTinhNv" type="radio" value="true" id="nam" checked="@(Model.GioiTinhNv == true)" />
                                <label for="nam">Nam</label>
                            </div>
                            <div class="radio-item">
                                <input asp-for="GioiTinhNv" type="radio" value="false" id="nu" checked="@(Model.GioiTinhNv == false)" />
                                <label for="nu">Nữ</label>
                            </div>
                        </div>
                    </div>

                    <div class="form-group col-md-6">
                        <label>Trạng thái hoạt động (Hiệu lực)</label>
                        <div class="checkbox-item mt-2">
                            <input asp-for="HieuLuc" type="checkbox" id="hieuLucCheckbox" />
                            <label for="hieuLucCheckbox" class="mb-0">Kích hoạt tài khoản</label>
                        </div>
                    </div>
                </div>


                <div class="text-center mt-5">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-save mr-2"></i> Cập nhật nhân viên
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('imagePreview').src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function togglePassword(fieldId, button) {
            const field = document.getElementById(fieldId);
            const icon = button.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.className = 'fas fa-eye-slash';
            } else {
                field.type = 'password';
                icon.className = 'fas fa-eye';
            }
        }
    </script>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
@model IEnumerable<FruitShopG4P.ViewModels.HangHoaVM>

@foreach (var item in Model)
{
    <div class="col-md-6 col-lg-6 col-xl-4 mb-4">
        <div class="rounded position-relative fruite-item shadow-sm">
            <div class="fruite-img">
                <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@item.MaHH">
                    <img class="img-fluid w-100 rounded-top" style="height:250px; object-fit:cover;" src="@Url.Content("~/Hinh/HangHoa/" + item.Hinh)" alt="@item.TenHH">
                </a>
            </div>

            <div class="text-white bg-green-theme px-3 py-1 rounded position-absolute" style="top: 10px; left: 10px;">
                Trái Cây
            </div>

            <div class="p-4 border border-light border-top-0 rounded-bottom bg-white">
                <a asp-action="Detail" asp-controller="HangHoa" asp-route-id="@item.MaHH" class="h5 d-block text-truncate product-title">
                    @item.TenHH
                </a>

                <p class="text-muted small description-truncate">@item.MoTaNgan</p>

                <div class="d-flex justify-content-between align-items-center flex-lg-wrap">
                    <div class="price-group">
                        <span class="text-dark fs-5 fw-bold">@item.DonGia đ</span>
                    </div>

                    <a asp-action="AddToCart" asp-controller="Cart" asp-route-id="@item.MaHH" class="btn btn-add-cart">
                        <i class="fa fa-shopping-bag me-2"></i> Thêm vào giỏ
                    </a>
                </div>
            </div>
        </div>
    </div>
}